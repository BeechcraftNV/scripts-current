#!/bin/bash
# git-sync - Universal script to sync any git repo with its remote "Gold Standard"
# Uses a fetch + rebase strategy to maintain a clean, linear history.

set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Parse arguments
USE_STASH=false
while [[ $# -gt 0 ]]; do
    case $1 in
        --stash)
            USE_STASH=true
            shift
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# 1. Verify we are in a git repository
if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo -e "${RED}✖ Error: Not in a git repository.${NC}"
    exit 1
fi

# 2. Identify environment
REPO_ROOT=$(git rev-parse --show-toplevel)
BRANCH=$(git branch --show-current)
REMOTE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null | cut -d/ -f1 || echo "origin")

echo -e "${BLUE}=== Syncing: $(basename "$REPO_ROOT") [$BRANCH] ===${NC}"

# 3. Fetch latest state from remote
echo "Fetching from $REMOTE..."
git fetch "$REMOTE"

# 4. Check for local changes (Dirty Tree)
HAS_CHANGES=false
if ! git diff-index --quiet HEAD --; then
    HAS_CHANGES=true
    if [ "$USE_STASH" = true ]; then
        echo -e "${YELLOW}📦 Local changes detected. Stashing...${NC}"
        git stash
    else
        echo -e "${YELLOW}⚠️  Local changes detected.${NC}"
        echo "Options:"
        echo "  1) Commit your work before syncing"
        echo "  2) Run 'git stash' to temporarily hide changes"
        echo "  3) Run 'git-sync --stash' to automate this"
        echo ""
        git status --short
        exit 1
    fi
fi

# 5. Check relationship with remote
LOCAL=$(git rev-parse HEAD)
UPSTREAM=$(git rev-parse "@{u}" 2>/dev/null || echo "")

if [ -z "$UPSTREAM" ]; then
    echo -e "${YELLOW}⚠️  No upstream branch set for '$BRANCH'.${NC}"
    # If we stashed, we should pop before exiting
    [ "$USE_STASH" = true ] && [ "$HAS_CHANGES" = true ] && git stash pop
    exit 1
fi

BASE=$(git merge-base HEAD "$UPSTREAM")
EXIT_CODE=0

if [ "$LOCAL" = "$UPSTREAM" ]; then
    echo -e "${GREEN}✓ Repository is already up-to-date.${NC}"
elif [ "$LOCAL" = "$BASE" ]; then
    echo -e "${BLUE}⬇️  Remote is ahead. Pulling updates...${NC}"
    git pull --rebase "$REMOTE" "$BRANCH"
    echo -e "${GREEN}✓ Updated successfully.${NC}"
elif [ "$UPSTREAM" = "$BASE" ]; then
    echo -e "${YELLOW}⬆️  Local is ahead. You have unpushed commits.${NC}"
    echo "Run 'git push' to update the gold standard."
else
    echo -e "${RED}✖ Diverged!${NC} Attempting auto-rebase..."
    if git pull --rebase "$REMOTE" "$BRANCH"; then
        echo -e "${GREEN}✓ Successfully rebased local changes.${NC}"
    else
        echo -e "${RED}✖ Conflict detected. Manual resolution required.${NC}"
        EXIT_CODE=1
    fi
fi

# 6. Re-apply stashed changes if necessary
if [ "$USE_STASH" = true ] && [ "$HAS_CHANGES" = true ]; then
    echo -e "${YELLOW}📦 Re-applying stashed changes...${NC}"
    if ! git stash pop; then
        echo -e "${RED}✖ Conflict while popping stash! Resolve manually.${NC}"
        EXIT_CODE=1
    fi
fi

if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ Done.${NC}"
else
    exit $EXIT_CODE
fi

#!/bin/bash
# sync-scripts - Robust synchronization with GitHub gold standard
# Features: Fetch, Rebase, Dirty-check, and Environment detection

set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

REPO_DIR="$HOME/.local/bin"
cd "$REPO_DIR"

echo -e "${BLUE}=== GitHub Gold Standard Sync ===${NC}"

# 1. Fetch latest state from GitHub
echo "Fetching from origin..."
git fetch origin

# 2. Check for local changes
if ! git diff-index --quiet HEAD --; then
    echo -e "${YELLOW}⚠️  Local changes detected.${NC}"
    echo "Options:"
    echo "  1) Commit changes manually first"
    echo "  2) Run: git stash && git pull --rebase && git stash pop"
    echo ""
    git status --short
    exit 1
fi

# 3. Check relationship with remote
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse @{u})
BASE=$(git merge-base HEAD @{u})

if [ "$LOCAL" = "$REMOTE" ]; then
    echo -e "${GREEN}✓ Local is already up-to-date with GitHub.${NC}"
elif [ "$LOCAL" = "$BASE" ]; then
    echo -e "${BLUE}⬇️  GitHub is ahead. Pulling updates...${NC}"
    git pull --rebase
    echo -e "${GREEN}✓ Updated to latest version.${NC}"
elif [ "$REMOTE" = "$BASE" ]; then
    echo -e "${YELLOW}⬆️  Local is ahead of GitHub. You should push your changes.${NC}"
    echo "Run: git push"
else
    echo -e "${RED}✖ Diverged! Local and GitHub have different commits.${NC}"
    echo "Attempting auto-rebase..."
    if git pull --rebase; then
        echo -e "${GREEN}✓ Successfully rebased local changes onto GitHub standard.${NC}"
    else
        echo -e "${RED}✖ Conflict detected. Manual resolution required.${NC}"
        exit 1
    fi
fi

echo -e "\n${BLUE}Current Status:${NC}"
echo "  Branch: $(git branch --show-current)"
echo "  Latest: $(git log -1 --oneline)"
echo -e "${GREEN}✅ Sync complete.${NC}"